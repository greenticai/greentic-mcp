// SPDX-License-Identifier: MIT
// Mirrors the secrets-store interface the generated MCP router imports, so the
// adapter can resolve a persisted OAuth token (self-gate) from the same store.

package greentic:secrets-store@1.0.0;

interface secrets-store {
  enum secrets-error {
    not-found,
    denied,
    invalid-key,
    internal,
  }

  get: func(key: string) -> result<option<list<u8>>, secrets-error>;
}
